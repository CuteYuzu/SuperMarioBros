<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <RootNamespace>osu.Game.Rulesets.SuperMarioBros</RootNamespace>
    <AssemblyName>osu.Game.Rulesets.SuperMarioBros</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ppy.osu.Game" Version="2026.317.0" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Mods\" />
    <Folder Include="Replays\" />
  </ItemGroup>

  <ItemGroup>
    <!-- 复制资源到输出目录 -->
    <Content Include="..\BaseAssets\Sprites\**\*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Resources\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
    
    <!-- 嵌入资源到程序集 -->
    <EmbeddedResource Include="..\BaseAssets\Sprites\**\*.*">
      <Link>Resources\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </EmbeddedResource>
  </ItemGroup>

</Project>
